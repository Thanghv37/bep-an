# Mẫu file .env cho dự án — copy file này thành `.env` rồi điền giá trị thật.
# File `.env` đã được gitignore, KHÔNG commit vào git.
# Trên server production, các biến này set trực tiếp trong systemd service file.

# Mật khẩu PostgreSQL của user `postgres`
DB_PASSWORD=your_db_password_here

# Django secret key — generate bằng:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Trên prod BẮT BUỘC set qua systemd, không dùng fallback trong code.
SECRET_KEY=replace_me_with_generated_key

# Bật DEBUG trên dev để xem stack trace. Trên prod phải để False.
DJANGO_DEBUG=True

# Danh sách host được phép, cách nhau bởi dấu phẩy.
# Dev có thể bỏ trống (code tự fallback localhost,127.0.0.1 khi DEBUG=True).
# Prod: net2kitchen.viettel.pro.vn,127.0.0.1
DJANGO_ALLOWED_HOSTS=

# (Tuỳ chọn) Google Gemini API key — nếu không set ở đây, admin có thể nhập
# vào trang Profile của Django và sẽ lưu trong bảng SystemConfig.
# GEMINI_API_KEY=AIza...
