# Mẫu file .env cho dự án — copy file này thành `.env` rồi điền giá trị thật.
# File `.env` đã được gitignore, KHÔNG commit vào git.
# Trên server production, các biến này set trực tiếp trong systemd service file.

# Mật khẩu PostgreSQL của user `postgres`
DB_PASSWORD=your_db_password_here

# (Tuỳ chọn) Google Gemini API key — nếu không set ở đây, admin có thể nhập
# vào trang Profile của Django và sẽ lưu trong bảng SystemConfig.
# GEMINI_API_KEY=AIza...
