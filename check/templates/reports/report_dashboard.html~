{% extends 'base.html' %}
{% load currency_filters %}

{% block title %}Báo cáo{% endblock %}
{% block page_title %}Báo cáo{% endblock %}

{% block content %}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="dashboard-card mb-4">
    <div class="section-title mb-1">Báo cáo thu - chi</div>
    <div class="section-subtitle mb-3">
        Theo dõi theo tuần hoặc tháng, hiển thị trực quan từng ngày dưới dạng card.
    </div>

    <form method="get">
        <div class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label fw-semibold">Chế độ xem</label>
                <select name="view_type" class="form-select" onchange="toggleFilters(this.value)">
                    <option value="week" {% if view_type == 'week' %}selected{% endif %}>Theo tuần</option>
                    <option value="month" {% if view_type == 'month' %}selected{% endif %}>Theo tháng</option>
                </select>
            </div>

            <div class="col-md-3" id="week-filter" {% if view_type != 'week' %}style="display:none;"{% endif %}>
                <label class="form-label fw-semibold">Chọn ngày trong tuần</label>
                <input type="date" name="selected_date" value="{{ selected_date }}" class="form-control">
            </div>

            <div class="col-md-2" id="month-filter" {% if view_type != 'month' %}style="display:none;"{% endif %}>
                <label class="form-label fw-semibold">Tháng</label>
                <select name="month" class="form-select">
                    {% for m in month_choices %}
                        <option value="{{ m }}" {% if m == selected_month %}selected{% endif %}>Tháng {{ m }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="col-md-2" id="year-filter" {% if view_type != 'month' %}style="display:none;"{% endif %}>
                <label class="form-label fw-semibold">Năm</label>
                <select name="year" class="form-select">
                    {% for y in year_choices %}
                        <option value="{{ y }}" {% if y == selected_year %}selected{% endif %}>{{ y }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Biểu đồ chênh lệch</label>
                <select name="balance_chart_type" class="form-select">
                    <option value="daily_in_month" {% if balance_chart_type == 'daily_in_month' %}selected{% endif %}>
                        Theo ngày trong tháng
                    </option>
                    <option value="monthly_in_year" {% if balance_chart_type == 'monthly_in_year' %}selected{% endif %}>
                        Theo tháng trong năm
                    </option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm px-3">Xem báo cáo</button>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-card mb-4">
    <div class="section-title mb-1">
        Khoảng báo cáo: {{ start_date|date:"d/m/Y" }} - {{ end_date|date:"d/m/Y" }}
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card stat-green">
            <div class="stat-label">Tổng Thu</div>
            <div class="stat-value">{{ total_income|vnd }} VNĐ</div>
            <div class="stat-meta">Tổng doanh thu</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-card stat-red">
            <div class="stat-label">Tổng Chi</div>
            <div class="stat-value">{{ total_expense|vnd }} VNĐ</div>
            <div class="stat-meta">Tổng chi phí thực tế</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-card {% if total_balance >= 0 %}stat-blue{% else %}stat-amber{% endif %}">
            <div class="stat-label">Tổng Chênh lệch</div>
            <div class="stat-value">{{ total_balance|vnd }} VNĐ</div>
            <div class="stat-meta">Thu - Chi</div>
        </div>
    </div>
</div>

<div class="dashboard-card mb-4">
    <div class="section-title mb-1">Biểu đồ theo ngày</div>
    <div class="section-subtitle mb-3">
        So sánh Thu, Chi và Chênh lệch trong khoảng thời gian đã chọn.
    </div>

    <canvas id="reportChart" height="110"></canvas>
</div>
<div class="dashboard-card mb-4">
    <div class="section-title mb-1">Biểu đồ chênh lệch Thu - Chi</div>
    <div class="section-subtitle mb-3">
        {% if balance_chart_type == 'daily_in_month' %}
            Hiển thị chênh lệch theo từng ngày trong tháng đã chọn.
        {% else %}
            Hiển thị chênh lệch theo từng tháng trong năm đã chọn.
        {% endif %}
    </div>

    <canvas id="balanceOnlyChart" height="100"></canvas>
</div>
<div class="dashboard-card">
    <div class="section-title mb-1">Chi tiết các ngày trong tháng</div>
    <div class="section-subtitle mb-3">
        Mỗi ô là một ngày, giúp theo dõi nhanh và trực quan hơn bảng dài.
    </div>

    <div class="row g-3">
        {% for row in daily_rows %}
        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
            <div class="p-3 border rounded-4 bg-white h-100">
                <div class="fw-bold mb-2">{{ row.date|date:"d/m/Y" }}</div>

                <div class="small text-muted mb-1">Người ăn</div>
                <div class="fw-semibold mb-2">{{ row.registered_count }}</div>

                <div class="small text-muted mb-1">Giá suất ăn</div>
                <div class="fw-semibold mb-2">{{ row.meal_price|vnd }} VNĐ</div>

                <div class="small text-muted mb-1">Thu</div>
                <div class="fw-semibold text-success mb-2">{{ row.income|vnd }} VNĐ</div>

                <div class="small text-muted mb-1">Chi</div>
                <div class="fw-semibold text-danger mb-2">{{ row.expense|vnd }} VNĐ</div>

                <div class="small text-muted mb-1">Chênh lệch</div>
                <div class="fw-semibold {% if row.balance >= 0 %}text-primary{% else %}text-warning{% endif %}">
                    {{ row.balance|vnd }} VNĐ
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>

<script>
    function toggleFilters(viewType) {
        const weekFilter = document.getElementById('week-filter');
        const monthFilter = document.getElementById('month-filter');
        const yearFilter = document.getElementById('year-filter');

        if (viewType === 'week') {
            weekFilter.style.display = 'block';
            monthFilter.style.display = 'none';
            yearFilter.style.display = 'none';
        } else {
            weekFilter.style.display = 'none';
            monthFilter.style.display = 'block';
            yearFilter.style.display = 'block';
        }
    }

    const chartLabels = {{ chart_labels|safe }};
    const incomeData = {{ income_data|safe }};
    const expenseData = {{ expense_data|safe }};
    const balanceData = {{ balance_data|safe }};

    const ctx = document.getElementById('reportChart').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: chartLabels,
            datasets: [
                {
                    label: 'Thu',
                    data: incomeData,
                    backgroundColor: 'rgba(34, 197, 94, 0.75)',
                    borderRadius: 6
                },
                {
                    label: 'Chi',
                    data: expenseData,
                    backgroundColor: 'rgba(239, 68, 68, 0.75)',
                    borderRadius: 6
                },
                {
                    label: 'Chênh lệch',
                    data: balanceData,
                    type: 'line',
                    borderColor: 'rgba(37, 99, 235, 1)',
                    backgroundColor: 'rgba(37, 99, 235, 0.15)',
                    tension: 0.35,
                    fill: false
                }
            ]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'top'
                }
            }
        }
    });
</script>

{% endblock %}